VITE_API_URL=http://localhost:8787/api
DATABASE_URL=postgresql://VK_USER:VK_PASSWORD@VK_HOST:5432/VK_DATABASE?sslmode=require
# Optional custom CA path for strict SSL verification.
# If omitted, backend will try ~/.postgresql/root.crt and fallback to ssl { rejectUnauthorized: false }.
# DATABASE_SSL_ROOT_CERT=C:\\Users\\your-user\\.postgresql\\root.crt
API_PORT=8787
CORS_ORIGIN=http://localhost:5173

# Optional credentials for scripts/api-smoke-test.ps1
# SMOKE_TEST_EMAIL=employee@example.com
# SMOKE_TEST_PASSWORD=your-password